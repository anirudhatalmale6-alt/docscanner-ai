{
  "cli": {
    "version": ">=10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-large",
        "image": "macos-sequoia-15.3-xcode-17.0"
      },
      "android": {
        "image": "ubuntu-22.04-jdk-23-ndk-28"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-large",
        "image": "macos-sequoia-15.3-xcode-17.0"
      },
      "android": {
        "image": "ubuntu-22.04-jdk-23-ndk-28",
        "buildType": "app-bundle"
      }
    }
  }
}
